						'pos_1_score' 					=> $arrPosScore[1],
						'pos_2_yes_no' 					=> $arrPosYN[2],
						'pos_2_score' 					=> $arrPosScore[2],
						'pos_3_yes_no' 					=> $arrPosYN[3],
						'pos_3_score' 					=> $arrPosScore[3],
