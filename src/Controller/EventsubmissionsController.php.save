        $condition = array();
		$condition[] = "(Eventsubmissions.convention_id = '".$conventionRegD->convention_id."')";
		$condition[] = "(Eventsubmissions.season_id = '".$conventionRegD->season_id."')";
		$condition[] = "(Eventsubmissions.season_year = '".$conventionRegD->season_year."')";
