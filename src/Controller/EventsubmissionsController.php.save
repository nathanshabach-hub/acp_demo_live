				{
					$bestScore = max($arrBestD);
				}
				else
				{
					$bestScore = NULL;
				}
				
				
				$eventsubmissionD 	= $this->Eventsubmissions->find()->where(['Eventsubmissions.id' => $submission_id])->contain(["Users","Students"])->first();
				
