				{
					$withdraw_yes_no = 1;
				}
				else
				{
					$withdraw_yes_no = 0;
				}
				
				if(empty($distance_attempt_1))
				{
					$distance_attempt_1 = NULL;
				}
				else
				{
					$arrBestD[] = $distance_attempt_1;
				}
				
				if(empty($distance_attempt_2))
				{
